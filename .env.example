# Copia a `.env` y completa. NO commitear `.env`.

# Supabase > Project Settings > Database > Connection string (Session pooler).
SUPABASE_DB_URL=postgresql://postgres.<project-ref>:<password>@<host>.pooler.supabase.com:5432/postgres

# --- Aviso al equipo de Mecsa cuando un tejedor envia su reporte ---
# Gmail exige una "contrasena de aplicacion" (no la del correo):
#   Google > Cuenta > Seguridad > Verificacion en 2 pasos > Contrasenas de aplicacion
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<usuario@boston.com.pe>
SMTP_PASS=<contrasena-de-aplicacion>

# Remitente y destinatarios (separados por coma). Solo equipo Mecsa: los
# tejedores no reciben copia.
MAIL_FROM=<usuario@boston.com.pe>
MAIL_TO=<destinatario1>,<destinatario2>

# Interruptor: false = el portal funciona igual pero no manda correos (util para probar).
MAIL_ENABLED=true
